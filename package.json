{
  "name": "soul-care-counselling",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "validate": "npm run lint && npm run type-check && npm run format:check",
    "validate:full": "npm run lint && npm run type-check && npm run format:check && npm run knip",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production') { try { require('child_process').execSync('husky', {stdio:'inherit'}) } catch(e) {} }\" ",
    "validate-legal-toc": "node scripts/validate-legal-toc.mjs",
    "seed-team": "node scripts/seed-team-members.js",
    "upload-images": "node scripts/upload-team-images.js",
    "test:send-email-local": "node ./scripts/test-send-email.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.485.0",
    "@aws-sdk/s3-request-presigner": "^3.485.0",
    "@portabletext/react": "^4.0.3",
    "@sanity/image-url": "^1.2.0",
    "@sanity/vision": "^4.6.1",
    "@sendgrid/mail": "^8.1.6",
    "autoprefixer": "^10.4.19",
    "busboy": "^1.6.0",
    "critters": "^0.0.23",
    "dotenv": "^17.2.2",
    "lucide-react": "^1.12.0",
    "next": "^15.5.9",
    "next-sanity": "^11.1.0",
    "postcss": "^8.4.39",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sanity": "^4.8.1",
    "styled-components": "^6.1.19",
    "tailwindcss": "^3.4.4",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.13.5",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^9.37.0",
    "eslint-config-next": "^15.5.9",
    "husky": "^9.1.7",
    "knip": "^6.12.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
